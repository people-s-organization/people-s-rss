# --- Auth (NextAuth + GitHub) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Create a GitHub OAuth App at https://github.com/settings/developers
# Authorization callback URL: https://<your-domain>/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# --- Storage (Redis) ---
# Used for the per-user sync blob and rate-limit counters.
# Either set REDIS_URL directly, or expose any *_REDIS_URL (Vercel Marketplace
# integrations like Upstash inject e.g. <name>_REDIS_URL automatically).
REDIS_URL=

# --- AI key encryption ---
# 32 random bytes, base64-encoded. Used to AES-256-GCM-encrypt each user's
# stored AI API key before it hits Redis.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# IMPORTANT: changing this value renders every stored AI key un-decryptable;
# users will have to re-enter their key in Settings.
AI_KEY_ENC_SECRET=
