# --- Auth (NextAuth + GitHub) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Create a GitHub OAuth App at https://github.com/settings/developers
# Authorization callback URL: https://<your-domain>/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# --- Storage (Upstash Redis) ---
# Used for rate-limit counters.
# Use a provider-direct Upstash Redis database, not Vercel-provisioned storage.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Storage (Supabase) ---
# Used for signed-in users, feeds, categories, public AI settings, and encrypted AI API keys.
# Use a provider-direct Supabase project service-role key. Never expose this
# key to the browser or prefix it with NEXT_PUBLIC_.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Supabase Postgres connection string used only by server-side sync transactions.
# Prefer Supabase's pooler connection string for serverless deployments.
SUPABASE_DATABASE_URL=

# --- AI key encryption ---
# 32 random bytes, base64-encoded. Used to AES-256-GCM-encrypt each user's
# stored AI API key before it hits Supabase.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# IMPORTANT: changing this value renders every stored AI key un-decryptable;
# users will have to re-enter their key in Settings.
AI_KEY_ENC_SECRET=
