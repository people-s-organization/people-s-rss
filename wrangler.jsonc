{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "people-s-rss",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-06-26",
  "compatibility_flags": ["nodejs_compat"],
  "keep_vars": true,
  "workers_dev": true,
  "preview_urls": false,
  "vars": {
    "PEOPLES_RSS_RUNTIME": "cloudflare"
  },
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  }
}
